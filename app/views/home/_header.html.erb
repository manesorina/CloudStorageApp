<nav class="navbar navbar-expand-lg custom-navbar">
  
  <% if user_signed_in? %>
    <%= link_to files_path, class: "navbar-brand" do %>
      <%= image_tag "logo.png", alt: "Logo", height: "50" %>
    <%end%>
  <% else %>
    <%= link_to root_path, class: "navbar-brand" do %>
      <%= image_tag "logo.png", alt: "Logo", height: "50" %>
    <%end%>

  <% end %>

  <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu"
          aria-controls="navbarMenu" aria-expanded="false" aria-label="Toggle navigation">
    <span class="navbar-toggler-icon"></span>
  </button>

  <div class="collapse navbar-collapse" id="navbarMenu">
    <ul class="navbar-nav ms-auto">
      <% if user_signed_in? %>
        <li class="nav-item">
          <%= link_to 'Home', files_path, class: "nav-link px-3" %>
        </li>
        <li class="nav-item">
          <%= link_to 'Edit Profile', edit_user_registration_path, class: "nav-link px-3" %>
        </li>
        <li class="nav-item">
          <%= button_to 'Sign Out', destroy_user_session_path, method: :delete,
                class: "btn btn-outline-light nav-link px-3 ", form_class: "d-inline" %>
        </li>
      <% else %>
        <li class="nav-item">
          <%= link_to 'Home', root_path, class: "nav-link" %>
        </li>
      <% end %>
    </ul>
  </div>
</nav>
