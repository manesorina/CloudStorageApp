<div class="container-fluid">
  <div class="row">
    <div class="col-12 text-center pt-2 pb-1">
      <%= image_tag "nick.png", alt: "Logo", style: "height: 200px; width: auto;" %>
    </div>
  </div>
</div>

<div class="container d-flex justify-content-center align-items-start mt-n3" style="min-height: 100vh;">
  <div class="card p-4" style="width: 400px; background-color:rgb(205, 228, 245);">
    <h3 class="text-center mb-3">Sign In</h3>
    
    
    <%= form_with scope: :user, url: user_session_path, local: true do |f| %>
      <div class="form-group mb-3">
        <%= f.label :email %>
        <%= f.email_field :email, class: "form-control", required: true, autofocus: true %>
      </div>
      
      <div class="form-group mb-3">
        <%= f.label :password %>
        <%= f.password_field :password, class: "form-control", required: true %>
      </div>
      
      <div class="form-group form-check mb-3">
        <%= f.check_box :remember_me, class: "form-check-input" %>
        <%= f.label :remember_me, class: "form-check-label" %>
      </div>
      
      <%= f.submit "Sign in", class: "btn btn-primary w-100" %>
    <% end %>
    
    <hr>
    
    <p class="text-center mb-2">
      Don't have an account?
      <%= link_to "Sign up", new_user_registration_path %>
    </p>
    
    <p class="text-center">
      <%= link_to "Forgot your password?", new_user_password_path %>
    </p>
  </div>
</div>