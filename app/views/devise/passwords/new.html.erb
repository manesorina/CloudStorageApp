<div class="container-fluid">
  <div class="row">
    <div class="col-12 text-center pt-2 pb-1">
      <%= image_tag "nick.png", alt: "Logo", style: "height: 200px; width: auto;" %>
    </div>
  </div>
</div>

<div class="container d-flex justify-content-center align-items-start mt-n3" style="min-height: 100vh;">
  <div class="card p-4" style="width: 400px; background-color:rgb(205, 228, 245);">
    <h3 class="text-center mb-3">Forgot your password?</h3>
    
    <!-- Error Messages -->
    <%= render "devise/shared/error_messages", resource: resource %>
    
    <!-- Success Notice -->
    <% if notice %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <%= notice %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% end %>
    
    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <div class="form-group mb-3">
        <%= f.label :email %>
        <%= f.email_field :email, class: "form-control", autofocus: true, autocomplete: "email", required: true %>
      </div>
      
      <%= f.submit "Send me reset password instructions", class: "btn btn-primary w-100" %>
    <% end %>
    
    <hr>
    
    <p class="text-center mb-2">
      Remember your password?
      <%= link_to "Sign in", new_user_session_path %>
    </p>
    
    <p class="text-center">
      Don't have an account?
      <%= link_to "Sign up", new_user_registration_path %>
    </p>
  </div>
</div>