<% if @file.destroyed? %>
  document.getElementById('file-<%= @file.id %>').remove();
  
  // Update the file count badge
  const badge = document.querySelector('.badge.bg-secondary');
  if (badge) {
    const currentCount = parseInt(badge.textContent);
    badge.textContent = currentCount - 1;
  }
  
  // Show empty state if no files left
  const filesContainer = document.querySelector('.files-container .row.g-3');
  if (filesContainer && filesContainer.children.length === 0) {
    filesContainer.innerHTML = `
      <div class="col-12">
        <div class="empty-state text-center p-4 border rounded bg-light">
          <i class="fas fa-cloud-upload-alt fa-3x text-muted"></i>
          <h5 class="mt-3">No files uploaded yet</h5>
          <p>Upload your first file to get started</p>
        </div>
      </div>
    `;
  }
<% end %>